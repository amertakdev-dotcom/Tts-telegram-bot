# ── Telegram ─────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# ── MongoDB ──────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=amertakBot

# ── Groq (used for /ask AND for the "copy text from image" OCR feature) ──
GROQ_API_KEY=your_groq_api_key_here
# Chat model for /ask
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
# Vision model for OCR — Groq model names change over time, check
# https://console.groq.com/docs/models if this stops working.
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Amertak backend (TTS + downloader + proxy-download) ────────────────────
# Base "/api" URL of https://amertak-cdn.onrender.com (or your own deployment)
API_BASE_URL=https://amertak-cdn.onrender.com/api
# Only needed if the backend's API_SECRET_KEY guard is enabled
API_SECRET_KEY=

# ── Render ───────────────────────────────────────────────────────────────
PORT=3000
